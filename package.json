{
  "name": "investment-purchase-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build:single-html",
    "preview": "vite preview",
    "build:single-html": "node scripts/build-single-html.mjs",
    "build:single-html:versioned-dist": "GENERATE_VERSIONED_HTML=1 VERSIONED_HTML_DIR=dist npm run build",
    "build:single-html:full": "npm run build",
    "single": "npm run build:single-html",
    "single:full": "npm run build:single-html:full"
  },
  "dependencies": {
    "idb": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
